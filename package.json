{
  "name": "ai-benchmark",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm run web:install",
    "dev": "concurrently -n bench,web -c blue,green \"tsx watch src/server.ts\" \"npm run web:dev\"",
    "build": "tsc -p tsconfig.json && npm run web:build",
    "start": "node dist/server.js",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:install": "npm --prefix web install"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
