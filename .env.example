# Todas as variáveis abaixo são OPCIONAIS — o app funciona sem nenhum .env.
# A chave OpenRouter NÃO vai aqui: ela é informada na própria UI (tela de setup).

# Endpoint da API OpenRouter (troque só se usar um proxy/gateway).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Headers de atribuição enviados ao OpenRouter (HTTP-Referer / X-Title).
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=Benchmark Arena

# Porta do servidor backend.
BENCHMARK_PORT=3001
